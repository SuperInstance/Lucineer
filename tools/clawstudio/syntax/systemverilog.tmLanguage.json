{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SystemVerilog (MLS Enhanced)",
  "scopeName": "source.systemverilog",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#mls-types" },
    { "include": "#operators" },
    { "include": "#system-tasks" },
    { "include": "#module-declaration" },
    { "include": "#preprocessor" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.systemverilog",
          "match": "//.*$"
        },
        {
          "name": "comment.block.systemverilog",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.systemverilog",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.systemverilog",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.sized.systemverilog",
          "match": "\\b\\d+'[bBhHoOdD][0-9a-fA-F_xXzZ]+\\b"
        },
        {
          "name": "constant.numeric.decimal.systemverilog",
          "match": "\\b\\d[\\d_]*\\b"
        },
        {
          "name": "constant.numeric.real.systemverilog",
          "match": "\\b\\d+\\.\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.systemverilog",
          "match": "\\b(if|else|case|casex|casez|for|while|do|foreach|repeat|forever|begin|end|fork|join|join_any|join_none|return|break|continue|disable|wait)\\b"
        },
        {
          "name": "keyword.declaration.systemverilog",
          "match": "\\b(module|endmodule|interface|endinterface|package|endpackage|class|endclass|function|endfunction|task|endtask|generate|endgenerate|program|endprogram)\\b"
        },
        {
          "name": "keyword.modifier.systemverilog",
          "match": "\\b(input|output|inout|ref|parameter|localparam|import|typedef|enum|struct|union|packed|signed|unsigned|const|static|automatic|virtual|pure|extern|local|protected|rand|randc)\\b"
        },
        {
          "name": "keyword.storage.systemverilog",
          "match": "\\b(reg|wire|logic|bit|byte|shortint|int|longint|integer|real|realtime|time|string|chandle|event|genvar|var)\\b"
        },
        {
          "name": "keyword.procedural.systemverilog",
          "match": "\\b(always|always_ff|always_comb|always_latch|assign|initial|final)\\b"
        },
        {
          "name": "keyword.assertion.systemverilog",
          "match": "\\b(assert|assume|cover|restrict|property|sequence|endproperty|endsequence)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.systemverilog",
          "match": "\\b(void|shortreal|string|type|mailbox|semaphore|process)\\b"
        }
      ]
    },
    "mls-types": {
      "patterns": [
        {
          "name": "support.type.mls.systemverilog",
          "match": "\\b(weight_t|state_t|command_t|reg_addr_t|status_t|power_domain_t|cascade_header_t)\\b"
        },
        {
          "name": "constant.language.mls.systemverilog",
          "match": "\\b(PLUS_ONE|ZERO|MINUS_ONE|RESERVED|IDLE|BUSY|INFERENCE_DONE|ERROR|LOAD_WEIGHTS|RUN_INFERENCE|READ_LOGITS|CASCADE_ESCALATE|CLEAR_KV_CACHE|SLEEP|WAKE)\\b"
        },
        {
          "name": "entity.name.module.mls.systemverilog",
          "match": "\\b(rau|synaptic_array|weight_rom|kv_cache|a2a_register_file|mls_common)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.systemverilog",
          "match": "(\\|->|\\|=>|##|@@|\\*>|=>|<=|>=|===|!==|==|!=|&&|\\|\\||<<|>>|<<<|>>>)"
        }
      ]
    },
    "system-tasks": {
      "patterns": [
        {
          "name": "support.function.system.systemverilog",
          "match": "\\$[a-zA-Z_][a-zA-Z0-9_$]*"
        }
      ]
    },
    "module-declaration": {
      "patterns": [
        {
          "name": "entity.name.type.module.systemverilog",
          "match": "(?<=\\bmodule\\s+)\\w+"
        }
      ]
    },
    "preprocessor": {
      "patterns": [
        {
          "name": "meta.preprocessor.systemverilog",
          "match": "`[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    }
  }
}
