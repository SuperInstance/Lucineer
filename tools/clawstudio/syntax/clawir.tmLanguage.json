{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ClawIR",
  "scopeName": "source.clawir",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#operations" },
    { "include": "#numbers" },
    { "include": "#labels" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.semicolon.clawir", "match": ";.*$" },
        { "name": "comment.line.double-slash.clawir", "match": "//.*$" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.clawir", "begin": "\"", "end": "\"" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.clawir",
          "match": "\\b(module|func|block|return|tensor|param|const|global)\\b"
        },
        {
          "name": "keyword.control.clawir",
          "match": "\\b(br|br_if|call|invoke|unreachable|yield)\\b"
        },
        {
          "name": "keyword.quantization.clawir",
          "match": "\\b(quantize|dequantize|ternary_encode|ternary_decode)\\b"
        },
        {
          "name": "keyword.scheduling.clawir",
          "match": "\\b(tile|fuse|partition|schedule|pipeline)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.clawir",
          "match": "\\b(i1|i2|i4|i8|i16|i32|i64|f16|f32|f64|ternary|tensor|void)\\b"
        },
        {
          "name": "support.type.tensor.clawir",
          "match": "tensor<[^>]+>"
        }
      ]
    },
    "operations": {
      "patterns": [
        {
          "name": "entity.name.function.clawir",
          "match": "\\b(matmul|conv2d|relu|gelu|softmax|layernorm|add|mul|reshape|transpose|concat|split|gather|attention|mlp|embed|rau_mac|zero_skip)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.clawir", "match": "\\b-?\\d+(\\.\\d+)?\\b" },
        { "name": "constant.numeric.hex.clawir", "match": "0x[0-9a-fA-F]+" }
      ]
    },
    "labels": {
      "patterns": [
        { "name": "entity.name.label.clawir", "match": "%[a-zA-Z_][a-zA-Z0-9_]*" },
        { "name": "entity.name.label.clawir", "match": "@[a-zA-Z_][a-zA-Z0-9_]*" }
      ]
    }
  }
}
