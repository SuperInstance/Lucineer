{
  "MLS RAU Module": {
    "prefix": "mls-rau",
    "body": [
      "module rau #(",
      "    parameter int WIDTH = ${1:8},",
      "    parameter int ACC_WIDTH = ${2:24}",
      ")(",
      "    input  logic                        clk,",
      "    input  logic                        rst_n,",
      "    input  logic signed [WIDTH-1:0]     activation,",
      "    input  logic [1:0]                  weight,",
      "    input  logic                        valid,",
      "    input  logic                        clear,",
      "    output logic signed [ACC_WIDTH-1:0] acc_out",
      ");",
      "",
      "    import mls_common::*;",
      "",
      "    logic signed [WIDTH-1:0] product;",
      "",
      "    // Weight decode — ternary: mux + inverter, no multiplier",
      "    always_comb begin",
      "        case (weight_t'(weight))",
      "            PLUS_ONE:  product = activation;",
      "            ZERO:      product = '0;",
      "            MINUS_ONE: product = -activation;",
      "            default:   product = '0; // Reserved encoding",
      "        endcase",
      "    end",
      "",
      "    // Pipelined accumulator",
      "    always_ff @(posedge clk or negedge rst_n) begin",
      "        if (!rst_n)",
      "            acc_out <= '0;",
      "        else if (clear)",
      "            acc_out <= '0;",
      "        else if (valid)",
      "            acc_out <= acc_out + ACC_WIDTH'(signed'(product));",
      "    end",
      "",
      "endmodule"
    ],
    "description": "MLS Rotation-Accumulate Unit (RAU) — multiplication-free ternary MAC"
  },
  "MLS Testbench": {
    "prefix": "mls-tb",
    "body": [
      "`timescale 1ns / 1ps",
      "",
      "module tb_${1:module_name};",
      "",
      "    // Parameters",
      "    parameter int CLK_PERIOD = 10;",
      "",
      "    // Signals",
      "    logic clk = 0;",
      "    logic rst_n = 0;",
      "",
      "    // Clock generation",
      "    always #(CLK_PERIOD/2) clk = ~clk;",
      "",
      "    // DUT instantiation",
      "    ${1:module_name} dut (",
      "        .clk(clk),",
      "        .rst_n(rst_n)${2}",
      "    );",
      "",
      "    // Test counters",
      "    int pass_count = 0;",
      "    int fail_count = 0;",
      "",
      "    task check(string name, logic [31:0] actual, logic [31:0] expected);",
      "        if (actual === expected) begin",
      "            $$display(\"  PASS: %s = 0x%0h\", name, actual);",
      "            pass_count++;",
      "        end else begin",
      "            $$display(\"  FAIL: %s = 0x%0h (expected 0x%0h)\", name, actual, expected);",
      "            fail_count++;",
      "        end",
      "    endtask",
      "",
      "    initial begin",
      "        $$display(\"=== ${1:module_name} Testbench ===\");",
      "",
      "        // Reset",
      "        rst_n = 0;",
      "        repeat(5) @(posedge clk);",
      "        rst_n = 1;",
      "        @(posedge clk);",
      "",
      "        // Test cases",
      "        ${3:// Add test cases here}",
      "",
      "        // Summary",
      "        $$display(\"\\n=== Results: %0d passed, %0d failed ===\", pass_count, fail_count);",
      "        if (fail_count > 0) $$fatal(1, \"TESTS FAILED\");",
      "        $$finish;",
      "    end",
      "",
      "    // Timeout watchdog",
      "    initial begin",
      "        #100_000;",
      "        $$fatal(1, \"TIMEOUT\");",
      "    end",
      "",
      "endmodule"
    ],
    "description": "MLS self-checking testbench with pass/fail counters and timeout"
  },
  "MLS Register File": {
    "prefix": "mls-regfile",
    "body": [
      "// A2A Register File — MLS v1.0 compliant",
      "module a2a_registers #(",
      "    parameter logic [31:0] CHIP_ID = 32'h${1:CLAW_0001}",
      ")(",
      "    input  logic        clk,",
      "    input  logic        rst_n,",
      "    // Bus interface",
      "    input  logic [7:0]  addr,",
      "    input  logic [31:0] wdata,",
      "    input  logic        wen,",
      "    output logic [31:0] rdata,",
      "    // Control outputs",
      "    output logic [7:0]  command,",
      "    output logic [1:0]  privacy_level,",
      "    // Status inputs",
      "    input  logic        ready,",
      "    input  logic        busy,",
      "    input  logic        inference_done,",
      "    input  logic [15:0] temperature",
      ");",
      "",
      "    import mls_common::*;",
      "",
      "    // Register storage",
      "    logic [31:0] cmd_reg;",
      "    logic [31:0] addr_reg;",
      "    logic [31:0] input_base;",
      "    logic [31:0] output_base;",
      "    logic [31:0] cascade_ctrl;",
      "    logic [31:0] privacy_reg;",
      "",
      "    assign command = cmd_reg[7:0];",
      "    assign privacy_level = privacy_reg[1:0];",
      "",
      "    // Write logic",
      "    always_ff @(posedge clk or negedge rst_n) begin",
      "        if (!rst_n) begin",
      "            cmd_reg      <= '0;",
      "            addr_reg     <= '0;",
      "            input_base   <= '0;",
      "            output_base  <= '0;",
      "            cascade_ctrl <= '0;",
      "            privacy_reg  <= '0;",
      "        end else if (wen) begin",
      "            case (addr)",
      "                8'h00: cmd_reg      <= wdata;",
      "                8'h08: addr_reg     <= wdata;",
      "                8'h10: input_base   <= wdata;",
      "                8'h14: output_base  <= wdata;",
      "                8'h20: cascade_ctrl <= wdata;",
      "                8'h24: privacy_reg  <= wdata;",
      "                default: ; // Ignore writes to read-only registers",
      "            endcase",
      "        end",
      "    end",
      "",
      "    // Read logic",
      "    always_comb begin",
      "        case (addr)",
      "            8'h00: rdata = cmd_reg;",
      "            8'h04: rdata = {16'b0, 4'b0, 4'b0, 3'b0, 1'b0, 1'b0, inference_done, busy, ready};",
      "            8'h08: rdata = addr_reg;",
      "            8'h10: rdata = input_base;",
      "            8'h14: rdata = output_base;",
      "            8'h18: rdata = CHIP_ID;",
      "            8'h1C: rdata = {16'b0, temperature};",
      "            8'h20: rdata = cascade_ctrl;",
      "            8'h24: rdata = privacy_reg;",
      "            default: rdata = 32'hDEAD_BEEF;",
      "        endcase",
      "    end",
      "",
      "endmodule"
    ],
    "description": "MLS A2A register file with standard offsets"
  },
  "MLS FSM": {
    "prefix": "mls-fsm",
    "body": [
      "// Inference FSM",
      "typedef enum logic [3:0] {",
      "    S_IDLE,",
      "    S_LOAD,",
      "    S_COMPUTE,",
      "    S_OUTPUT,",
      "    S_DONE",
      "} fsm_state_t;",
      "",
      "fsm_state_t state, next_state;",
      "",
      "always_ff @(posedge clk or negedge rst_n) begin",
      "    if (!rst_n)",
      "        state <= S_IDLE;",
      "    else",
      "        state <= next_state;",
      "end",
      "",
      "always_comb begin",
      "    next_state = state;",
      "    case (state)",
      "        S_IDLE:    if (start) next_state = S_LOAD;",
      "        S_LOAD:    if (load_done) next_state = S_COMPUTE;",
      "        S_COMPUTE: if (compute_done) next_state = S_OUTPUT;",
      "        S_OUTPUT:  if (output_done) next_state = S_DONE;",
      "        S_DONE:    next_state = S_IDLE;",
      "        default:   next_state = S_IDLE;",
      "    endcase",
      "end"
    ],
    "description": "MLS inference FSM template"
  },
  "MLS Systolic Array Generate": {
    "prefix": "mls-array",
    "body": [
      "// ${1:ROWS}×${2:COLS} systolic array of RAUs",
      "generate",
      "    for (genvar r = 0; r < ${1:ROWS}; r++) begin : gen_row",
      "        for (genvar c = 0; c < ${2:COLS}; c++) begin : gen_col",
      "            rau #(",
      "                .WIDTH(${3:8}),",
      "                .ACC_WIDTH(${4:24})",
      "            ) u_rau (",
      "                .clk(clk),",
      "                .rst_n(rst_n),",
      "                .activation(act_bus[c]),",
      "                .weight(weight_rom[r][c]),",
      "                .valid(valid),",
      "                .clear(clear),",
      "                .acc_out(partial_sum[r][c])",
      "            );",
      "        end",
      "    end",
      "endgenerate"
    ],
    "description": "MLS systolic array with generate blocks"
  },
  "MLS SVA Assertion": {
    "prefix": "mls-assert",
    "body": [
      "// MLS Compliance Assertion: ${1:description}",
      "assert property (@(posedge clk) disable iff (!rst_n)",
      "    ${2:antecedent} |-> ${3:consequent}",
      ") else $$error(\"MLS violation: ${1:description}\");"
    ],
    "description": "SystemVerilog Assertion for MLS compliance"
  }
}
