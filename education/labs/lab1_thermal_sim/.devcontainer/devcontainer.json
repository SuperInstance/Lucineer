{
  "name": "MLS Lab 1 - Thermal Simulation",
  "image": "ghcr.io/superinstance/mls-lab-base:latest",
  "features": {
    "ghcr.io/devcontainers/features/python:1": { "version": "3.11" }
  },
  "postCreateCommand": "pip install numpy matplotlib scipy && echo 'Lab 1 environment ready'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ]
    }
  },
  "forwardPorts": [8888],
  "remoteUser": "vscode"
}
