# SuperInstance Ranch — Environment Configuration
# Copy this to .env and fill in your values

# Database (SQLite for local, PostgreSQL for production)
DATABASE_URL="file:./db/ranch.db"

# Next.js
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: External LLM API fallback (Ranch works fully offline without this)
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

# Jetson GPU settings (leave empty for auto-detect)
# CUDA_DEVICE="0"
# GPU_MEMORY_FRACTION="0.9"

# Ranch configuration
RANCH_NAME="my-ranch"
BREEDING_SCHEDULE="0 2 * * *"  # 2am nightly by default
MAX_HERD_SIZE="100"
NIGHT_SCHOOL_ENABLED="true"
